Rule 38    location -> ID
Rule 39    location -> location PUNTO ID
Rule 40    if_statement -> IF L_PAREN expression R_PAREN L_BRACKET statement_list R_BRACKET
Rule 41    if_statement -> IF L_PAREN expression R_PAREN L_BRACKET statement_list R_BRACKET ELSE L_BRACKET statement_list R_BRACKET
Rule 42    while_statement -> WHILE L_PAREN expression R_PAREN L_BRACKET statement_list R_BRACKET
Rule 43    do_while_statement -> DO L_BRACKET statement_list R_BRACKET WHILE L_PAREN expression R_PAREN PUNTO_COMA
Rule 44    record_decl -> RECORD ID L_PAREN param_list R_PAREN PUNTO_COMA
Rule 45    function_call -> ID L_PAREN arg_list R_PAREN
Rule 46    function_call -> PRINT L_PAREN arg_list R_PAREN
Rule 47    arg_list -> arg_list_items
Rule 48    arg_list -> empty
Rule 49    arg_list_items -> arg_list_items COMA expression
Rule 50    arg_list_items -> expression
Rule 51    instantiation -> NEW ID L_PAREN arg_list R_PAREN
Rule 52    expression -> expression SUMA expression
Rule 53    expression -> expression RESTA expression
